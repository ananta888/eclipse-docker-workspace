.gradle
**/build/
!**/src/**/build/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Avoid ignore Gradle wrappper properties
!gradle-wrapper.properties

# Cache of project
.gradletasknamecache

# Eclipse Gradle plugin generated files
# Eclipse Core
.project
# JDT-specific (Eclipse Java Development Tools)
.classpath
/portable/*
/portable/cache/
/portable/eclipse-win/
/portable/repos/
/portable/vscodium-win/
/portable/workspace/
/portable/workspace-vscodium/
/.idea/
.env
/eclipse-data/
/bootstrap.log
!/portable/start-eclipse-win11.bat
!/portable/start-vscodium-win11.bat
