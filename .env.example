TZ=Europe/Berlin
ECLIPSE_IMAGE_TAG=latest
NOVNC_PORT=6080
VNC_PORT=5900
WORKSPACE_DIR=./portable/workspace
REPOS_DIR=./repos
ECLIPSE_HOME_DIR=./eclipse-data/home
SHARED_DIR=./shared
BACKUP_DIR=./backup
DISABLE_SAROS=1

# Optional: 1 = Eclipse direkt auf Host-X11 anzeigen (statt noVNC)
USE_HOST_X11=0

# Optional: X-Server auf Windows (z. B. VcXsrv)
HOST_DISPLAY=host.docker.internal:0.0

# Optional: eigener Saros-XMPP Server via docker-compose.saros.yml
SAROS_XMPP_PORT=5222
SAROS_HTTP_PORT=5280
